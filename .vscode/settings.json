{
  "eslint.workingDirectories": [
    {
      "mode": "auto"
    }
  ],
  "javascript.validate.enable": false,
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "files.exclude": {
    "node_modules": true,
    "**/node_modules": false,
    "**/.cargo/**": true,
    ".claude": true,
    ".gemini": true,
    ".cursor": true,
    "CURSOR.md": true,
    "GEMINI.md": true,
    "CODEX.md": true,
    "CLAUDE.md": true,
  },
  "search.exclude": {
    "node_modules": true,
    "**/node_modules": false,
    "**/.cargo/**": true,
    ".claude": true,
    ".gemini": true,
    ".cursor": true,
    "CURSOR.md": true,
    "GEMINI.md": true,
    "CODEX.md": true,
    "CLAUDE.md": true,
  },
  "files.watcherExclude": {
    "node_modules": true,
    "**/node_modules": false,
    "**/.cargo/**": true,
    ".claude": true,
    ".gemini": true,
    ".cursor": true,
    "CURSOR.md": true,
    "GEMINI.md": true,
    "CODEX.md": true,
    "CLAUDE.md": true,
  },
  "git.ignoreLimitWarning": true,
  "typescript.tsdk": "node_modules/typescript/lib"
}