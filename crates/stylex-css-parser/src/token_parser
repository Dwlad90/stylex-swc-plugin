#[cfg(test)]
mod tests {
  use super::*;

  #[test]
    fn test_token_list() {
      let input_str = "div { color: red; }";
      let mut input_buffer = ParserInput::new(input_str);
      let parser = Parser::new(&mut input_buffer);

      // Create a copy of parser to avoid lifetime issues
      let mut list = {
        let mut buffer_copy = ParserInput::new(input_str);
        let parser_copy = Parser::new(&mut buffer_copy);
        TokenList::new(parser_copy)
      };
      assert!(list.consume_next_token().is_some());
      assert!(list.peek().is_some());
    }

  #[test]
  fn test_basic_parser() {
    let parser = TokenParser::new(
      |tokens| match tokens.consume_next_token() {
        Some(_) => Ok("Found a token"),
        None => Err(TokenParseError::new("No token found")),
      },
      "BasicParser",
    );

    assert!(parser.parse("div").is_ok());
    assert!(parser.parse("").is_err());
  }
}
