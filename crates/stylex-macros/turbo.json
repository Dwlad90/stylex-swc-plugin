{
  "$schema": "https://turbo.build/schema.json",
  "extends": [
    "//"
  ],
  "tags": [
    "rust-crate"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^do:nothing"
      ],
      "outputs": [
        "dist/**/*"
      ]
    },
    "test": {
      "dependsOn": [
        "^do:nothing"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^do:nothing"
      ],
      "outputs": []
    },
    "bench": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    }
  }
}
