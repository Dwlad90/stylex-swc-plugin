{
  "extends": "@stylexswc/typescript-config/base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "types": ["node"],
    "moduleResolution": "Node",
    "module": "CommonJS",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "benchmark", "__test__", "dist"]
}
