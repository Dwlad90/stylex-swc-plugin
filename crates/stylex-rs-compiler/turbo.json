{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tags": ["rust-crate", "rs-compiler"],
  "tasks": {
    "build": {
      "dependsOn": ["^do:nothing"],
      "outputs": ["dist/**/*"]
    },
    "test": {
      "dependsOn": ["build", "^do:nothing"]
    },
    "typecheck": {
      "dependsOn": ["^do:nothing"],
      "outputs": []
    },
    "bench": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
