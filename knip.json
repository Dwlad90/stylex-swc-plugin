{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        "husky",
        "commitizen",
        "cz-conventional-changelog",
        "lint-staged",
        "@commitlint/cli",
        "scripty",
        "shellcheck",
        "prettier"
      ]
    },
    "apps/*": {
      "ignoreDependencies": [
        "@stylexjs/eslint-plugin",
        "eslint-config-next",
        "react-refresh",
        "@swc/jest"
      ]
    },
    "apps/example-storybook": {
      "ignoreDependencies": [
        "@stylexjs/eslint-plugin",
        "eslint-config-next",
        "react-refresh",
        "@swc/jest",
        "@storybook/addon-vitest",
        "@typescript-eslint/eslint-plugin",
        "@typescript-eslint/parser",
        "@vitejs/plugin-react-swc",
        "@vitest/browser",
        "@vitest/browser-playwright",
        "@vitest/coverage-v8",
        "autoprefixer",
        "eslint-plugin-import",
        "postcss-nesting",
        "prop-types",
        "rollup-plugin-jsx-remove-attributes",
        "rollup-plugin-node-externals",
        "typescript-eslint",
        "vite-plugin-dts"
      ]
    },
    "apps/farm-unplugin-example": {
      "playwright": false,
      "ignoreDependencies": [
        "@stylexjs/eslint-plugin",
        "eslint-config-next",
        "react-refresh",
        "@swc/jest",
        "@farmfe/core",
        "@farmfe/plugin-react"
      ]
    },
    "apps/solid-unplugin-example": {
      "playwright": false,
      "ignoreDependencies": [
        "@stylexjs/eslint-plugin",
        "eslint-config-next",
        "react-refresh",
        "@swc/jest"
      ]
    },
    "packages/*": {},
    "crates/*": {}
  },
  "ignoreBinaries": ["lint-prepush", "cargo", "rustup", "scripty", "python3"],
  "ignoreDependencies": ["@stylexswc/.*"]
}
