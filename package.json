{
  "name": "@stylexswc/stylexswc",
  "version": "0.15.5",
  "private": true,
  "scripts": {
    "bench": "turbo run bench --continue",
    "build": "turbo run build",
    "check:artifacts": "turbo run check:artifacts --continue",
    "clean": "turbo clean",
    "deps:check": "./scripts/deps-prune.sh",
    "deps:check:node": "./scripts/deps-prune.sh --node",
    "deps:check:rust": "./scripts/deps-prune.sh --rust",
    "deps:fix": "./scripts/deps-prune.sh --apply",
    "dev": "turbo dev",
    "docs": "scripty  --rust",
    "format": "turbo run format --continue",
    "format:check": "turbo run format:check --continue",
    "lint": "turbo lint --continue",
    "lint:check": "turbo run lint:check --continue",
    "lint:crates:workspace": "cargo clippy --all-targets --all-features --workspace -- -D warnings",
    "prepare": "husky",
    "test": "turbo run test --continue",
    "test:coverage": "turbo run test:coverage --continue",
    "test:coverage:workspace": "cargo +nightly llvm-cov nextest --workspace --all-features --exclude stylex_logs --exclude stylex_compiler_rs --exclude stylex_test_parser --exclude stylex_css_parser --exclude stylex_transform --fail-uncovered-lines 0 --fail-uncovered-regions 0 --fail-under-functions 0 --ignore-filename-regex '(tests?|benches?|examples)/'",
    "test:crates:workspace": "turbo run test:crates:workspace:regular test:crates:workspace:doc --filter=// --continue",
    "test:crates:workspace:doc": "cargo test --doc --workspace --all-features",
    "test:crates:workspace:regular": "cargo nextest run --workspace --all-features",
    "test:flamegraph": "turbo run test:flamegraph --continue",
    "test:visual": "turbo run test:visual",
    "typecheck": "turbo run typecheck --continue"
  },
  "config": {
    "scripty": {
      "path": "./scripts/packages"
    }
  },
  "dependencies": {
    "scripty": "3.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@stylexswc/eslint-config": "0.15.5",
    "@stylexswc/typescript-config": "0.15.5",
    "@typescript-eslint/parser": "^8.56.1",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "del-cli": "^7.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jsonc": "^3.1.2",
    "husky": "^9.1.7",
    "knip": "^6.9.0",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "shellcheck": "^4.1.0",
    "syncpack": "^14.0.0",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "overrides": {
      "@babel/core@<7.26.10": ">=7.26.10",
      "@babel/helpers@<7.26.10": "7.26.10",
      "@babel/runtime@<7.26.10": ">=7.26.10",
      "@eslint/plugin-kit@<0.3.3": ">=0.3.3 <1.0.0",
      "@farmfe/core@<1.7.10": ">=1.7.11 <2.0.0",
      "@isaacs/brace-expansion@<=5.0.0": ">=5.0.1 <6.0.0",
      "@stylexjs/stylex@<0.17.3": ">=0.17.3",
      "@types/webpack@<5.0.0": ">=5.0.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": ">=8.18.0 <9.0.0",
      "brace-expansion@>=1.0.0 <=1.1.12": ">=1.1.13 <2.0.0",
      "brace-expansion@>=2.0.0 <=2.0.2": ">=2.0.3 <3.0.0",
      "cross-spawn@<6.0.6": ">=6.0.6",
      "cross-spawn@>=7.0.0 <7.0.5": ">=7.0.5",
      "esbuild@<=0.24.2": ">=0.25.0",
      "flatted@<3.4.2": ">=3.4.2 <4.0.0",
      "form-data@>=4.0.0 <4.0.4": ">=4.0.4 <5.0.0",
      "handlebars@<4.7.9": ">=4.7.9",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0 <11.0.0",
      "glob@>=11.0.0 <11.1.0": ">=11.1.0 <12.0.0",
      "http-proxy-middleware@<2.0.9": ">=2.0.9",
      "http-proxy-middleware@>=3 <3.0.5": ">=3.0.5",
      "js-yaml@<3.14.2 <4.0.0": ">=3.14.2 <4.0.0",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1 <5.0.0",
      "koa@>=2.0.0 <2.16.4": ">=2.16.4 <3.0.0",
      "lodash@<4.18.0": ">=4.18.0 <5.0.0",
      "micromatch@<4.0.8": ">=4.0.8",
      "minimatch@<3.1.4": ">=3.1.4 <4.0.0",
      "minimatch@>=10.0.0 < 10.2.3": ">=10.2.3 <11.0.0",
      "minimatch@>=9.0.0 < 9.0.7": ">=9.0.7 <10.0.0",
      "nanoid@<3.3.8": ">=3.3.8",
      "node-forge@<1.4.0": ">=1.4.0 <2.0.0",
      "on-headers@<1.1.0": ">=1.1.0 <2.0.0",
      "path-to-regexp@<0.1.13": ">=0.1.13",
      "picomatch@<4.0.4": ">=4.0.4",
      "qs@<6.14.2": ">=6.14.2 <7.0.0",
      "svgo@4.0.0": "4.0.1",
      "rollup@>=4.0.0 <4.59.0": ">=4.59.0 <5.0.0",
      "serialize-javascript@<=7.0.4": ">=7.0.5 <8.0.0",
      "tar@<7.5.8": ">=7.5.8 <8.0.0",
      "tmp@<= 0.2.3": ">=0.2.4 <1.0.0",
      "webpack@<5.0.0": ">=5.0.0",
      "yauzl@<3.2.1": ">=3.2.1 <4.0.0"
    },
    "patchedDependencies": {
      "scripty@3.0.0": "patches/scripty@3.0.0.patch"
    },
    "onlyBuiltDependencies": [
      "@swc/core",
      "core-js",
      "core-js-pure",
      "esbuild",
      "oxc-resolver",
      "sharp",
      "unrs-resolver"
    ]
  },
  "repository": "dwlad90/stylex-swc-plugin"
}
