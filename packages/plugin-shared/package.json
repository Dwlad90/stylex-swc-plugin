{
  "name": "@stylexswc/plugin-shared",
  "description": "Shared core for StyleX webpack and Rspack plugins powered by a Rust NAPI-RS/SWC compiler: loaders, plugin core, and CSS extraction logic.",
  "version": "0.18.0",
  "bugs": "https://github.com/Dwlad90/stylex-swc-plugin/issues",
  "config": {
    "scripty": {
      "path": "../../scripts/packages"
    }
  },
  "dependencies": {
    "@stylexjs/babel-plugin": "^0.19.0",
    "@stylexswc/rs-compiler": "0.18.0",
    "loader-utils": "^3.3.1"
  },
  "devDependencies": {
    "@stylexswc/eslint-config": "0.18.0",
    "@stylexswc/typescript-config": "0.18.0",
    "@types/loader-utils": "^3.0.0",
    "@types/node": "^26.1.0",
    "vitest": "^4.1.9",
    "webpack": "^5.108.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./stylex-loader": {
      "types": "./dist/stylex-loader.d.ts",
      "import": "./dist/stylex-loader.js",
      "require": "./dist/stylex-loader.js"
    },
    "./stylex-virtual-css-loader": {
      "types": "./dist/stylex-virtual-css-loader.d.ts",
      "import": "./dist/stylex-virtual-css-loader.js",
      "require": "./dist/stylex-virtual-css-loader.js"
    },
    "./stylex.css": "./dist/stylex.css",
    "./stylex-virtual.css": "./dist/stylex-virtual.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/Dwlad90/stylex-swc-plugin/tree/develop/packages/plugin-shared#readme",
  "keywords": [
    "atomic-css",
    "css-extraction",
    "css-in-js",
    "napi-rs",
    "rspack",
    "rust",
    "stylex",
    "swc",
    "webpack"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "private": false,
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dwlad90/stylex-swc-plugin.git",
    "directory": "packages/plugin-shared"
  },
  "scripts": {
    "build": "scripty --ts",
    "check:artifacts": "scripty",
    "clean": "del-cli dist",
    "lint": "eslint . --color",
    "lint:check": "eslint . --color --format json --output-file dist/eslint_report.json",
    "postbuild": "pnpm run check:artifacts",
    "prebuild": "pnpm run clean",
    "precommit": "lint-staged",
    "prepublishOnly": "pnpm run build",
    "prepush": "lint-prepush",
    "test": "vitest run",
    "typecheck": "scripty --ts"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
