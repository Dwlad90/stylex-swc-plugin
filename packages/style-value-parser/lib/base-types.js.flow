declare export class SubString {
  +string: string;
  startIndex: number;
  endIndex: number;
  constructor(str: string): void;
  startsWith(str: string): boolean;
  get first(): string;
  get(relativeIndex: number): string;
  toString(): string;
  get isEmpty(): boolean;
}
