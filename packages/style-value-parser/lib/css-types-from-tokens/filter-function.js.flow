declare export class GrayscaleFilterFunction extends FilterFunction {
  +amount: number;
  constructor(amount: number): void;
  toString(): string;
  static get parser(): TokenParser<GrayscaleFilterFunction>;
}

declare export class HueRotateFilterFunction extends FilterFunction {
  +angle: Angle;
  constructor(angle: Angle): void;
  toString(): string;
  static get parser(): TokenParser<HueRotateFilterFunction>;
}

declare export class InverFilterFunction extends FilterFunction {
  +amount: number;
  constructor(amount: number): void;
  toString(): string;
  static get parser(): TokenParser<InverFilterFunction>;
}

declare export class OpacityFilterFunction extends FilterFunction {
  +amount: number;
  constructor(amount: number): void;
  toString(): string;
  static get parser(): TokenParser<OpacityFilterFunction>;
}

declare export class SaturateFilterFunction extends FilterFunction {
  +amount: number;
  constructor(amount: number): void;
  toString(): string;
  static get parser(): TokenParser<SaturateFilterFunction>;
}

declare export class SepiaFilterFunction extends FilterFunction {
  +amount: number;
  constructor(amount: number): void;
  toString(): string;
  static get parser(): TokenParser<SepiaFilterFunction>;
}
