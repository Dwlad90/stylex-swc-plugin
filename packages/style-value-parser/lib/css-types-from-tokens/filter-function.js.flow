import { TokenParser } from '../core2';
import { Length } from './length';
// import { Color } from './color';
import { Angle } from './angle';

declare export class FilterFunction {
  toString(): string;
  static get parser(): TokenParser<FilterFunction>;
}

declare export class BlurFilterFunction extends FilterFunction {
  +radius: Length;
  constructor(radius: Length): void;
  toString(): string;
  static get parser(): TokenParser<BlurFilterFunction>;
}

declare export class BrightnessFilterFunction extends FilterFunction {
  +percentage: number;
  constructor(percentage: number): void;
  toString(): string;
  static get parser(): TokenParser<BrightnessFilterFunction>;
}

declare export class ContrastFilterFunction extends FilterFunction {
  +amount: number;
  constructor(amount: number): void;
  toString(): string;
  static get parser(): TokenParser<ContrastFilterFunction>;
}

