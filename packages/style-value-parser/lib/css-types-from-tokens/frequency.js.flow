import { TokenParser } from '../core2';

declare export class Frequency {
  +value: number;
  +unit: 'Hz' | 'KHz';
  constructor(value: number, unit: 'Hz' | 'KHz'): void;
  toString(): string;
  static UNITS: $ReadOnlyArray<'Hz' | 'KHz'>;
  static get parser(): TokenParser<Frequency>;
}
