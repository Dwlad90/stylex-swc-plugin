import { TokenParser } from '../core2';

declare export const UNITS_BASED_ON_FONT: $FlowFixMe;

declare export const UNITS_BASED_ON_VIEWPORT: $FlowFixMe;

declare export const UNITS_BASED_ON_CONTAINER: $FlowFixMe;

declare export const UNITS_BASED_ON_ABSOLUTE_UNITS: $FlowFixMe;
declare export class Length {
  +value: number;
  +unit: string;
  constructor(value: number, unit: string): void;
  toString(): string;
  static UNITS: $ReadOnlyArray<string>;
  static get parser(): TokenParser<Length>;
}

// Additional classes for other units can be added similarly
