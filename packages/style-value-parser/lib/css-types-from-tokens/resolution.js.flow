import { TokenParser } from '../core2';
type Unit = 'dpi' | 'dpcm' | 'dppx';

declare export class Resolution {
  +value: number;
  +unit: Unit;
  constructor(value: number, unit: Unit): void;
  toString(): string;
  static UNITS: $ReadOnlyArray<Unit>;
  static get parser(): TokenParser<Resolution>;
}
