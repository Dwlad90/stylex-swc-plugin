import { TokenParser } from '../token-parser';

declare export class Time {
  +value: number;
  +unit: 's' | 'ms';
  constructor(value: number, unit: 's' | 'ms'): void;
  toString(): string;
  static UNITS: $ReadOnlyArray<'s' | 'ms'>;
  static get parser(): TokenParser<Time>;
}
