import { Length } from './length';

import { TokenParser } from '../token-parser';
import { Angle } from './angle';
import type { LengthPercentage } from './length-percentage';

declare export class TransformFunction {
  static get parser(): TokenParser<TransformFunction>;
}

declare export class Matrix extends TransformFunction {
  +a: number;
  +b: number;
  +c: number;
  +d: number;
  +tx: number;
  +ty: number;
  constructor(
    a: number,
    b: number,
    c: number,
    d: number,
    tx: number,
    ty: number,
  ): void;
  toString(): string;
  static get parser(): TokenParser<Matrix>;
}

declare export class Matrix3d extends TransformFunction {
  +args: $ReadOnly<
    [
      number,
      number,
      number,
      number,
      number,
      number,
      number,
      number,
      number,
      number,
      number,
      number,
      number,
      number,
      number,
      number,
    ],
  >;
  constructor(args: this['args']): void;
  toString(): string;
  static get parser(): TokenParser<Matrix3d>;
}

declare export class Perspective extends TransformFunction {
  +length: Length;
  constructor(length: Length): void;
  toString(): string;
  static get parser(): TokenParser<Perspective>;
}

declare export class Rotate extends TransformFunction {
  +angle: Angle;
  constructor(angle: Angle): void;
  toString(): string;
  static get parser(): TokenParser<Rotate>;
}

declare export class RotateXYZ extends TransformFunction {
  +x: Angle;
  +axis: 'X' | 'Y' | 'Z';
  constructor(x: this['x'], axis: this['axis']): void;
  toString(): string;
  static get parser(): TokenParser<RotateXYZ>;
}

declare export class Rotate3d extends TransformFunction {
  +x: number;
  +y: number;
  +z: number;
  +angle: Angle;
  constructor(x: number, y: number, z: number, angle: Angle): void;
  toString(): string;
  static get parser(): TokenParser<Rotate3d>;
}

