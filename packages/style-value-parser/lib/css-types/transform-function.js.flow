declare export class Scale extends TransformFunction {
  +sx: number;
  +sy: void | number;
  constructor(sx: this['sx'], sy?: ?this['sy']): void;
  toString(): string;
  static get parser(): TokenParser<Scale>;
}

declare export class Scale3d extends TransformFunction {
  +sx: number;
  +sy: number;
  +sz: number;
  constructor(sx: this['sx'], sy: this['sy'], sz: this['sz']): void;
  toString(): string;
  static get parser(): TokenParser<Scale3d>;
}

declare export class ScaleAxis extends TransformFunction {
  +s: number;
  +axis: 'X' | 'Y' | 'Z';
  constructor(s: this['s'], axis: this['axis']): void;
  toString(): string;
  static get parser(): TokenParser<ScaleAxis>;
}

declare export class Skew extends TransformFunction {
  +ax: Angle;
  +ay: void | Angle;
  constructor(ax: this['ax'], ay?: ?this['ay']): void;
  toString(): string;
  static get parser(): TokenParser<Skew>;
}

declare export class SkewAxis extends TransformFunction {
  +a: Angle;
  +axis: 'X' | 'Y';
  constructor(a: this['a'], axis: this['axis']): void;
  toString(): string;
  static get parser(): TokenParser<SkewAxis>;
}

declare export class Translate extends TransformFunction {
  +tx: LengthPercentage;
  +ty: void | LengthPercentage;
  constructor(tx: this['tx'], ty?: ?this['ty']): void;
  toString(): string;
  static get parser(): TokenParser<Translate>;
}

declare export class Translate3d extends TransformFunction {
  +tx: LengthPercentage;
  +ty: LengthPercentage;
  +tz: Length;
  constructor(tx: LengthPercentage, ty: LengthPercentage, tz: Length): void;
  toString(): string;
  static get parser(): TokenParser<Translate3d>;
}

declare export class TranslateAxis extends TransformFunction {
  +t: LengthPercentage;
  +axis: 'X' | 'Y' | 'Z';
  constructor(t: LengthPercentage, axis: 'X' | 'Y' | 'Z'): void;
  toString(): string;
  static get parser(): TokenParser<TranslateAxis>;
}
