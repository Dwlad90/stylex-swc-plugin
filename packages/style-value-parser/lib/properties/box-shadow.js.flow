import { TokenParser } from '../token-parser';
import { Length } from '../css-types/length';
import { Color } from '../css-types/color';

declare export class BoxShadow {
  +offsetX: Length;
  +offsetY: Length;
  +blurRadius: Length;
  +spreadRadius: Length;
  +color: Color;
  +inset: boolean;
  constructor(
    offsetX: Length,
    offsetY: Length,
    blurRadius: Length,
    spreadRadius: Length,
    color: Color,
    inset: boolean,
  ): void;
  static get parse(): TokenParser<BoxShadow>;
}

declare export class BoxShadowList {
  +shadows: $ReadOnlyArray<BoxShadow>;
  constructor(shadows: $ReadOnlyArray<BoxShadow>): void;
  static get parse(): TokenParser<BoxShadowList>;
}
