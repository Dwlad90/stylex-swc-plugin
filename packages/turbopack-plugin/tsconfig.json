{
  "extends": "@stylexswc/typescript-config/base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "dist",
    "types": [
      "node"
    ],
    "ignoreDeprecations": "6.0",
    "moduleResolution": "Node",
    "module": "CommonJS",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
