{
  "extends": "@stylexswc/typescript-config/base.json",
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "es2017",
    "lib": [
      "esnext",
      "DOM"
    ],
    "module": "esnext",
    "types": [
      "node",
      "jest"
    ],
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "strict": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "virtual-css.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "__tests__/**/*.ts",
    "__tests__/**/*.tsx",
    "__tests__/**/*.mts"
  ],
  "exclude": [
    "node_modules"
  ]
}
