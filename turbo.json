{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    ".eslintrc.js",
    ".prettierrc.js",
    "Cargo.toml",
    "clippy.toml",
    "package.json",
    "turbo.json",
    "typings/**"
  ],
  "globalEnv": [
    "NODE_ENV",
    "STYLEX_DEBUG",
    "PORT"
  ],
  "futureFlags": {
    "errorsOnlyShowHash": true
  },
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**/*",
        "npm/**/*",
        ".next/**",
        "!.next/cache/**",
        "storybook-static/**/*"
      ],
      "outputLogs": "errors-only"
    },
    "clean": {
      "cache": false,
      "outputLogs": "errors-only"
    },
    "artifacts": {
      "cache": false,
      "outputs": [
        "dist/**/*"
      ],
      "outputLogs": "errors-only"
    },
    "check:artifacts": {
      "cache": false,
      "dependsOn": [
        "^build",
        "build"
      ],
      "outputLogs": "errors-only"
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "outputLogs": "errors-only"
    },
    "lint:check": {
      "outputs": [
        "dist/eslint_report.json"
      ],
      "outputLogs": "errors-only"
    },
    "@stylexswc/rs-compiler#lint:check": {
      "dependsOn": [
        "^build",
        "build"
      ],
      "outputLogs": "errors-only"
    },
    "@stylexswc/rs-compiler#test": {
      "dependsOn": [
        "^build",
        "build"
      ],
      "outputLogs": "errors-only"
    },
    "@stylexswc/path-resolver#lint:check": {
      "dependsOn": [
        "^build",
        "build"
      ],
      "outputLogs": "errors-only"
    },
    "@stylexswc/core#lint:check": {
      "dependsOn": [
        "^build",
        "build"
      ],
      "outputLogs": "errors-only"
    },
    "@stylexswc/shared#lint:check": {
      "dependsOn": [
        "^build",
        "build"
      ],
      "outputLogs": "errors-only"
    },
    "@stylexswc/test-parser#lint:check": {
      "dependsOn": [
        "^build",
        "build"
      ],
      "outputLogs": "errors-only"
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [],
      "outputLogs": "errors-only"
    },
    "test": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "**/__swc_snapshots__",
        "**/__snapshots__"
      ],
      "outputLogs": "errors-only"
    },
    "format:check": {
      "outputLogs": "errors-only"
    },
    "format": {
      "cache": false,
      "outputs": [
        "**/src/**/*.{ts,tsx,md,json,jsonc,toml,rs,js,jsx,cjs,mjs,css,scss,html,xml,yml,yaml,mdx}"
      ]
    },
    "bench": {
      "dependsOn": [
        "^build",
        "build"
      ],
      "cache": false,
      "outputLogs": "errors-only"
    },
    "test:visual": {
      "dependsOn": [
        "^build",
        "build"
      ],
      "outputs": [
        "**/.playwright-snapshots"
      ],
      "outputLogs": "errors-only"
    }
  }
}