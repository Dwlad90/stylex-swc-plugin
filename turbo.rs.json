{
  "$schema": "https://turbo.build/schema.json",
  "extends": [
    "//"
  ],
  "tags": [
    "rust-crate"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^do:nothing"
      ],
      "outputs": [
        "dist/**/*"
      ]
    },
    "test": {
      "dependsOn": [
        "^do:nothing"
      ]
    },
    "typecheck": {
      "dependsOn": [
        "^do:nothing"
      ],
      "outputs": []
    },
    "bench": {
      "dependsOn": [
        "build"
      ],
      "cache": false
    },
    "test:coverage": {
      "dependsOn": [
        "^do:nothing"
      ],
      "cache": false,
      "outputs": [
        "target/tarpaulin/**/*",
        "target/tarpaulin-json/**/*",
        "**/*.profraw"
      ]
    },
    "test:flamegraph": {
      "dependsOn": [
        "^do:nothing"
      ],
      "cache": false,
      "outputs": [
        "**/flamegraph.svg",
        "target/flamegraph/**/*"
      ]
    }
  }
}
